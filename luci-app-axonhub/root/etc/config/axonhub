config axonhub 'main'
	option config_version '3'
	option enabled '0'
	option listen_addr '0.0.0.0'
	option port 'auto'
	option data_dir 'auto'
	option memory_limit '512MiB'
	option gomaxprocs '2'
	option max_open_conns '10'
	option max_idle_conns '5'
	option log_level 'info'
	option log_to_syslog '0'
	option log_cleanup_schedule 'weekly'
