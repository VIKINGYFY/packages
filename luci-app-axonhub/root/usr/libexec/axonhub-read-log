#!/bin/sh

. /lib/functions.sh
. /usr/share/axonhub/runtime.sh

STORAGE_HELPER=/usr/libexec/axonhub-find-storage

config_load axonhub
config_get data_dir main data_dir 'auto'
config_get_bool log_to_syslog main log_to_syslog 0

if [ "$log_to_syslog" -eq 1 ]; then
	logread -e 'axonhub' 2>/dev/null | tail -n 100
	exit 0
fi

if [ "$data_dir" = 'auto' ]; then
	data_dir="$($STORAGE_HELPER)" || exit 1
fi
data_dir="$(normalize_directory "$data_dir")"
validate_directory "$data_dir" || exit 1

log_file="$data_dir/axonhub.log"
tail -n 100 "$log_file" 2>/dev/null
