{
	"luci-app-axonhub": {
		"description": "Grant access to luci-app-axonhub",
		"read": {
			"ubus": {
				"luci.axonhub": [ "status", "info", "log" ],
				"service": [ "list" ]
			},
			"uci": [ "axonhub" ]
		},
		"write": {
			"ubus": {
				"luci.axonhub": [ "action", "cron" ]
			},
			"uci": [ "axonhub" ]
		}
	}
}
