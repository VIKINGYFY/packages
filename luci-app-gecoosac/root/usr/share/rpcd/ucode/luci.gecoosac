#!/usr/bin/ucode

'use strict';

import { access, glob, lsdir, popen, readlink, realpath, rmdir, stat, unlink } from 'fs';
import { init_action, process_list } from 'luci.sys';
import { cursor } from 'uci';

const binpath = '/usr/bin/gecoosac';
const defaultUploadDir = '/tmp/gecoosac/upload/';
const protectedDirs = {
	'/': true,
	'/bin': true,
	'/dev': true,
	'/etc': true,
	'/lib': true,
	'/mnt': true,
	'/overlay': true,
	'/proc': true,
	'/rom': true,
	'/root': true,
	'/sbin': true,
	'/sys': true,
	'/tmp': true,
	'/usr': true,
	'/var': true
};

function process_status() {
	let result = {
		exists: !!access(binpath, 'x'),
		running: false
	};
	let pid = 0;

	for (let path in glob('/proc/[0-9]*/exe')) {
		let target = readlink(path);
		if (target != binpath && target != binpath + ' (deleted)')
			continue;

		let fields = match(path, /^\/proc\/([0-9]+)\/exe$/);
		if (fields) {
			pid = +fields[1];
			break;
		}
	}

	if (!pid)
		return result;

	result.running = true;
	result.pid = pid;

	for (let proc in process_list()) {
		if (+proc.PID != pid)
			continue;

		result.cpu = proc['%CPU'];
		result.memory = proc['%MEM'];
		break;
	}

	return result;
}

function sanitize_path(path) {
	path = trim(path || defaultUploadDir);

	if (!match(path, /^\//))
		return { ok: false, message: 'path must be absolute' };

	path = replace(path, /\/+$/, '');

	if (path == '')
		path = '/';

	for (let part in split(path, '/'))
		if (part == '..')
			return { ok: false, message: 'path must not contain ..' };

	if (protectedDirs[path])
		return { ok: false, message: 'refusing to clear protected directory ' + path };

	return { ok: true, path: path };
}

function remove_contents(path) {
	let deleted = 0;
	let errors = [];
	let entries = lsdir(path);

	if (entries == null)
		return { deleted: 0, errors: [ 'failed to list ' + path ] };

	for (let name in entries) {
		if (name == '.' || name == '..')
			continue;

		let full = path + '/' + name;
		let target = readlink(full);

		if (target != null) {
			if (unlink(full))
				deleted++;
			else
				push(errors, 'failed to remove symbolic link ' + full);

			continue;
		}

		let st = stat(full);

		if (st?.type == 'directory') {
			let child = remove_contents(full);
			deleted += child.deleted;

			for (let err in child.errors)
				push(errors, err);

			if (rmdir(full))
				deleted++;
			else
				push(errors, 'failed to remove directory ' + full);
		}
		else if (unlink(full)) {
			deleted++;
		}
		else {
			push(errors, 'failed to remove ' + full);
		}
	}

	return { deleted: deleted, errors: errors };
}

const methods = {
	status: {
		call: function() {
			return process_status();
		}
	},

	action: {
		args: { action: 'string' },
		call: function(request) {
			switch (request.args.action) {
			case 'start':
			case 'restart':
				let rc = init_action('gecoosac', request.args.action);
				return { success: rc === 0, code: rc };
			default:
				return { success: false, code: 2, message: 'invalid action' };
			}
		}
	},

	log: {
		call: function() {
			let fd = popen('/usr/libexec/gecoosac-read-log');
			if (!fd)
				return { log: '' };

			let output = fd.read('all') || '';
			fd.close();

			return { log: output };
		}
	},

	cron: {
		call: function() {
			let rc = init_action('gecoosac', 'sync_cron');
			return { success: rc === 0, code: rc };
		}
	},

	clear_upload: {
		call: function() {
			let uci = cursor();
			let checked = sanitize_path(uci.get('gecoosac', 'config', 'upload_dir') || defaultUploadDir);

			if (!checked.ok)
				return { success: false, deleted: 0, message: checked.message };

			let resolved = realpath(checked.path);
			if (!resolved || resolved != checked.path)
				return { success: false, deleted: 0, message: 'upload directory must not contain symbolic links' };

			let st = stat(checked.path);

			if (st?.type != 'directory')
				return { success: false, deleted: 0, message: 'upload directory does not exist' };

			let result = remove_contents(checked.path);

			return {
				success: length(result.errors) == 0,
				deleted: result.deleted,
				errors: result.errors
			};
		}
	}
};

return { 'luci.gecoosac': methods };
